{
  "name": "judgesystem",
  "version": "0.1.0",
  "private": true,
  "description": "Bid Eligibility Judgment System",
  "workspaces": [
    "packages/backend",
    "packages/frontend",
    "packages/shared"
  ],
  "scripts": {
    "pipeline:l1": "bash scripts/context-impact/l1-search.sh",
    "pipeline:quality": "bash scripts/context-impact/quality-gate.sh",
    "pipeline:classify": "bash scripts/context-impact/classify-task.sh",
    "pipeline:dashboard": "bash scripts/context-impact/pipeline-dashboard.sh",
    "pipeline:plan:init": "bash scripts/context-impact/plan-init.sh",
    "pipeline:plan:status": "bash scripts/context-impact/plan-status.sh",
    "pipeline:plan:clean": "bash scripts/context-impact/plan-clean.sh",
    "pipeline:record": "bash scripts/context-impact/record-run.sh",
    "test": "echo \"No tests configured yet\" && exit 0",
    "typecheck": "tsc -p scripts/tsconfig.json --noEmit",
    "ci:workflow-lint": "bash scripts/ci/run-workflow-lint.sh",
    "ci:python-syntax": "bash scripts/ci/check-python-syntax.sh",
    "ci:shell-syntax": "bash scripts/ci/check-shell-syntax.sh",
    "ci:migrations:validate": "bash scripts/ci/validate-migrations.sh",
    "automation:smoke": "bash scripts/automation/smoke/full-autonomy.sh",
    "automation:water-spider": "tsx scripts/water-spider.ts",
    "agents:parallel:exec": "tsx scripts/agents-parallel-exec.ts",
    "deploy:cloud-run:backend": "bash scripts/automation/deploy/cloud-run.sh backend",
    "deploy:cloud-run:frontend": "bash scripts/automation/deploy/cloud-run.sh frontend",
    "state:check": "tsx scripts/label-state-machine.ts check",
    "state:transition": "tsx scripts/label-state-machine.ts transition",
    "state:assign-agent": "tsx scripts/label-state-machine.ts assign-agent",
    "fetch:partners": "docker compose -f deploy/docker-compose.yml --profile tools run --rm fetch-partners"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.20.0",
    "@octokit/graphql": "^9.0.3",
    "@octokit/rest": "^22.0.1"
  }
}
