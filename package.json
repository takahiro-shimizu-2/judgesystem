{
  "name": "judgesystem",
  "version": "0.1.0",
  "private": true,
  "description": "Bid Eligibility Judgment System",
  "workspaces": ["packages/backend", "packages/frontend", "packages/shared"],
  "scripts": {
    "pipeline:l1": "bash ../context-and-impact/src/cli/l1-keyword-search.sh",
    "pipeline:quality": "python3 ../context-and-impact/src/quality/ensemble_judge.py",
    "pipeline:classify": "python3 ../context-and-impact/src/routing/multi_classifier.py",
    "pipeline:dashboard": "npx agent-skill-bus dashboard",
    "pipeline:plan:init": "bash scripts/context-impact/plan-init.sh",
    "pipeline:plan:status": "bash scripts/context-impact/plan-status.sh",
    "pipeline:plan:clean": "bash scripts/context-impact/plan-clean.sh",
    "pipeline:record": "bash scripts/context-impact/record-run.sh",
    "test": "echo \"No tests configured yet\" && exit 0",
    "typecheck": "tsc -p scripts/tsconfig.json --noEmit",
    "agents:parallel:exec": "tsx scripts/agents-parallel-exec.ts",
    "state:check": "tsx scripts/label-state-machine.ts check",
    "state:transition": "tsx scripts/label-state-machine.ts transition",
    "state:assign-agent": "tsx scripts/label-state-machine.ts assign-agent",
    "fetch:partners": "docker compose -f deploy/docker-compose.yml --profile tools run --rm fetch-partners"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.20.0",
    "@octokit/graphql": "^9.0.3",
    "@octokit/rest": "^22.0.1",
    "agent-skill-bus": "file:../agent-skill-bus",
    "miyabi": "file:../Miyabi/packages/cli"
  }
}
