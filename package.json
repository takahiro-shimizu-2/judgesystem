{
  "name": "judgesystem",
  "version": "1.0.0",
  "private": true,
  "description": "入札適格性判定システム (Bid Eligibility Judgment System)",
  "scripts": {
    "dev:backend": "cd source/bid_apps/postgres/backend/app && npm run dev",
    "dev:frontend": "cd source/bid_apps/postgres/frontend/app && npm run dev",
    "build:backend": "cd source/bid_apps/postgres/backend/app && npm run build",
    "build:frontend": "cd source/bid_apps/postgres/frontend/app && npm run build",
    "typecheck:backend": "cd source/bid_apps/postgres/backend/app && npx tsc --noEmit",
    "typecheck:frontend": "cd source/bid_apps/postgres/frontend/app && npx tsc --noEmit",
    "lint:frontend": "cd source/bid_apps/postgres/frontend/app && npm run lint",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  }
}
