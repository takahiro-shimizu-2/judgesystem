@startuml page-layout
!theme plain
skinparam backgroundColor #FEFEFE

title 入札可否判定システム UI - ページレイアウト図

rectangle "MainLayout" as main #E2E8F0 {

  rectangle "Sidebar\n(64-160px)" as sidebar #0F172A {
    rectangle "メニュー" as menu #1E293B {
      note as menuItems
        - 判定結果
        - 入札案件
        - 会社情報
        - 発注者
        - 分析
      end note
    }
  }

  rectangle "Page Content (flex: 1)" as content #FAFAFA {

    rectangle "一覧ページ (カード形式)" as listPage #F8FAFC {
      rectangle "DataGrid カード\n(flex: 1)\nborderRadius: 4px" as gridCard #FFFFFF {
        rectangle "ヘッダー" as header #F8FAFC
        rectangle "DataGrid" as grid #FFFFFF
        rectangle "Pagination" as pagination #F8FAFC
      }

      rectangle "右パネル\n(320px)\nborderRadius: 4px" as rightPanel #FFFFFF {
        rectangle "詳細プレビュー" as preview #F8FAFC
      }
    }

  }
}

sidebar -[hidden]right-> content
gridCard -[hidden]right-> rightPanel

note bottom of main
  背景色: #e2e8f0 (colors.page.background)
  borderRadius: 4px (borderRadius.xs) 統一
end note

@enduml
