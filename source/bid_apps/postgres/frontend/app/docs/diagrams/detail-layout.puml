@startuml detail-layout
!theme plain
skinparam backgroundColor #FEFEFE

title 入札可否判定システム UI - 詳細ページレイアウト図

rectangle "BidDetailPage" as page #E2E8F0 {

  rectangle "Header (グラデーション背景)" as header #1E3A5F {
    rectangle "タイトル | ステータス | 優先度 | 見積金額" as headerContent #334155
  }

  rectangle "Content Area" as content {

    rectangle "Left Panel\n(280px)\n#FFFFFF" as leftPanel #FFFFFF {
      rectangle "発注者情報" as ordererInfo #F8FAFC {
        note as ordererNote
          組織名
          担当者
          電話/メール/FAX
          住所
        end note
      }
      rectangle "企業情報" as companyInfo #F8FAFC {
        note as companyNote
          企業名
          支店名
          連絡先
        end note
      }
    }

    rectangle "Center Content\n(flex: 1)\n#FAFAFA" as center #FAFAFA {
      rectangle "Workflow Stepper" as stepper #F8FAFC
      rectangle "Tab Content" as tabs #FFFFFF {
        note as tabNote
          判定 | 発注者 | 協力会社 | 依頼 | 落札
        end note
      }
      rectangle "Action Buttons" as actions #F8FAFC
    }

    rectangle "Right Panel\n(320px)\n#FFFFFF" as rightPanel #FFFFFF {
      rectangle "入札情報" as bidInfo #F8FAFC {
        note as bidNote
          概要情報
          スケジュール
          資料リンク
        end note
      }
    }

  }
}

leftPanel -[hidden]right-> center
center -[hidden]right-> rightPanel

note bottom of page
  3カラムレイアウト
  borderRadius: 4px 統一
  パネル区切り: borderRight/Left
end note

@enduml
