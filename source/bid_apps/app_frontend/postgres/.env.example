# Frontend Environment Variables Example

# ==========================================
# API設定
# ==========================================
# バックエンドAPIのベースURL
#
# 開発環境（ローカル）: http://localhost:8080
# 本番環境: https://bidapp-backend-postgres-50843898931.asia-northeast1.run.app
#
# ※ Viteでは VITE_ プレフィックスが必要
VITE_API_URL=http://localhost:8080

# ==========================================
# ビルド設定
# ==========================================
# 本番ビルド時は以下のように設定:
# VITE_API_URL=https://bidapp-backend-postgres-50843898931.asia-northeast1.run.app
