# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Source code
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.py text eol=lf
*.sh text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sql text eol=lf
*.txt text eol=lf

# Docker
Dockerfile text eol=lf
*.dockerfile text eol=lf

# Git config
.gitignore text eol=lf
.gitattributes text eol=lf

# Binary files (explicitly marked)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.db binary
