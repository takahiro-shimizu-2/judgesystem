{
  "mcpServers": {
    "miyabi": {
      "command": "node",
      "args": [
        ".claude/mcp-servers/miyabi-integration.js"
      ],
      "env": {
        "MIYABI_CLI": "${MIYABI_CLI}",
        "MIYABI_ROOT": "${MIYABI_ROOT}"
      },
      "disabled": false,
      "description": "Miyabi CLI統合 (optional external bridge) - MIYABI_CLI / MIYABI_ROOT override → local install → sibling fallback"
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      },
      "disabled": false,
      "description": "GitHub統合 - Issue/PR管理、Repository操作"
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "."
      ],
      "disabled": false,
      "description": "ファイルシステムアクセス"
    }
  }
}
