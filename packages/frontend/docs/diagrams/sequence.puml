@startuml sequence
!theme plain
skinparam backgroundColor #FEFEFE

title 入札可否判定システム UI - データフロー シーケンス図

actor User
participant "BidListPage" as Page
participant "useBidListState" as Hook
participant "DataGrid" as Grid
participant "FilterModal" as Filter
participant "localStorage" as Storage
database "evaluations.ts" as Data

== 初期表示 ==
User -> Page: アクセス
activate Page

Page -> Hook: useBidListState()
activate Hook
Hook -> Storage: getItem('bidListFilters')
Storage --> Hook: savedFilters
Hook -> Data: import evaluations
Data --> Hook: mockEvaluations
Hook --> Page: { filters, rows, ... }
deactivate Hook

Page -> Grid: render(rows, columns)
activate Grid
Grid --> User: 一覧表示
deactivate Grid
deactivate Page

== フィルタリング ==
User -> Page: フィルターボタンクリック
activate Page
Page -> Filter: open()
activate Filter
Filter --> User: モーダル表示

User -> Filter: 条件選択
Filter -> Hook: onFilterChange(newFilters)
activate Hook
Hook -> Storage: setItem('bidListFilters', newFilters)
Hook -> Hook: filterData(evaluations, newFilters)
Hook --> Page: filteredRows
deactivate Hook

Filter --> User: モーダル閉じる
deactivate Filter

Page -> Grid: render(filteredRows)
activate Grid
Grid --> User: フィルタ済み一覧表示
deactivate Grid
deactivate Page

== 詳細画面遷移 ==
User -> Grid: 行クリック
activate Grid
Grid -> Page: onRowClick(params)
deactivate Grid

activate Page
Page -> Page: navigate(`/detail/${id}`)
Page --> User: BidDetailPage表示
deactivate Page

@enduml
