# Backend Environment Variables Example

# ==========================================
# CORS設定
# ==========================================
# フロントエンドのオリジン（CORS許可URL）
# 開発環境: http://localhost:5173
# 本番環境: https://bidapp-frontend-postgres-50843898931.asia-northeast1.run.app
CORS_ORIGIN=http://localhost:5173

# ==========================================
# PostgreSQL接続設定
# ==========================================
# 接続文字列（DATABASE_URLを使う場合）
# DATABASE_URL=postgresql://user:password@host:port/database

# または個別設定
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=postgres
PGUSER=postgres
PGPASSWORD=your_password_here

# ==========================================
# PostgreSQL SSL設定
# ==========================================
# SSL接続モード（disable / require / verify-ca / verify-full）
# 開発環境: disable
# 本番環境: require 以上を推奨
PGSSLMODE=require
# node-pg の SSL 有効化フラグ（PGSSLMODE=require の場合は true にしてください）
PGSSL=true
PGSSL_REJECT_UNAUTHORIZED=false

# ==========================================
# スキーマ設定
# ==========================================
# PostgreSQLスキーマプレフィックス（オプション）
# PG_SCHEMA=public

# ==========================================
# 認証設定
# ==========================================
# JWT認証を有効化（falseの場合、全リクエストがadminとして扱われる）
# WARNING: 本番環境では必ず true に設定してください。
#          false のままデプロイすると全APIが認証なしでアクセス可能になります。
AUTH_ENABLED=false
# JWTシークレットキー（本番環境では必ず変更してください）
JWT_SECRET=your-secret-key-change-in-production

# ==========================================
# サーバー設定
# ==========================================
# ポート番号（Cloud Runでは自動設定されます）
PORT=8080
